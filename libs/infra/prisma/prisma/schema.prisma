// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

enum ReceiptStatus {
  pending
  processing
  done
  failed
}

enum ReceiptSource {
  photo
  manual
}

model User {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String  @unique @db.VarChar(255)
  passwordHash String  @map("password_hash")
  fullName     String  @map("full_name") @db.VarChar(120)
  avatarUrl    String? @map("avatar_url")
  currencyCode String  @default("USD") @map("currency_code") @db.Char(3)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz // soft delete

  sessions   UserSession[]
  receipts   Receipt[]
  categories Category[]

  @@map("users")
  @@index([email])
}

model UserSession {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @unique @map("refresh_token_hash")
  deviceInfo       String?  @map("device_info")
  ipAddress        String?  @map("ip_address") @db.Inet
  expiresAt        DateTime @map("expires_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
  // indexes for logout-all and cron purging
  @@index([userId])
  @@index([expiresAt])
}

model Merchant {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @db.VarChar(200)
  normalizedName String   @unique @map("normalized_name") @db.VarChar(200)
  address        String?
  city           String?  @db.VarChar(100)
  countryCode    String?  @map("country_code") @db.Char(2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  receipts Receipt[]

  @@map("merchants")
  @@index([normalizedName])
}

model Receipt {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  merchantId   String?       @map("merchant_id") @db.Uuid
  title        String?       @db.VarChar(200)
  totalAmount  Decimal       @map("total_amount") @db.Decimal(12, 2)
  currencyCode String        @default("USD") @map("currency_code") @db.Char(3)
  purchaseDate DateTime      @map("purchase_date") @db.Date
  status       ReceiptStatus @default(pending)
  source       ReceiptSource @default(photo)
  notes        String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  user     User           @relation(fields: [userId], references: [id])
  merchant Merchant?      @relation(fields: [merchantId], references: [id])
  images   ReceiptImage[]
  items    ExpenseItem[]

  @@map("receipts")
  // pagination, analytics, and soft-delete filtering
  @@index([userId, purchaseDate(sort: Desc)])
  @@index([userId, deletedAt])
  @@index([merchantId])
}

model ReceiptImage {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiptId     String        @map("receipt_id") @db.Uuid
  storageKey    String        @unique @map("storage_key")
  mimeType      String        @map("mime_type") @db.VarChar(50)
  fileSizeBytes Int           @map("file_size_bytes")
  ocrStatus     ReceiptStatus @default(pending) @map("ocr_status")
  ocrRawText    String?       @map("ocr_raw_text")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@map("receipt_images")
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid // NULL for system categories
  name      String   @db.VarChar(80)
  colorHex  String   @map("color_hex") @db.Char(7)
  iconSlug  String?  @map("icon_slug") @db.VarChar(50)
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user  User?         @relation(fields: [userId], references: [id])
  items ExpenseItem[]

  @@map("categories")
  // fetching mixed system/user categories
  @@index([userId, isSystem])
}

model ExpenseItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiptId  String   @map("receipt_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  name       String   @db.VarChar(200)
  amount     Decimal  @db.Decimal(12, 2)
  quantity   Int      @default(1)
  unit       String?  @db.VarChar(40)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  receipt  Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@map("expense_items")
  // deep analytics aggregations and fast receipt loading
  @@index([receiptId])
  @@index([categoryId, receiptId])
}
